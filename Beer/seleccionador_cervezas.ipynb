    "\n",
    "import streamlit as st\n",
    "import pandas as pd\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "# 1. CONFIGURACIÓN DE LA PÁGINA\n",
    "st.set_page_config(page_title=\"Beer Selector Pro\", page_icon=\"🍺\", layout=\"wide\")\n",
    "\n",
    "# 2. TÍTULO Y DESCRIPCIÓN\n",
    "st.title(\"🍺 Seleccionador de Cervezas para Portafolio\")\n",
    "st.markdown(\"\"\"\n",
    "Esta aplicación utiliza **Machine Learning (K-Means Clustering)** para agrupar estilos de cerveza \n",
    "por su perfil técnico y ayudarte a encontrar la opción ideal según tus gustos.\n",
    "\"\"\")\n",
    "\n",
    "# 3. CARGA Y PREPROCESAMIENTO (Asegúrate de que 'df_model' esté disponible)\n",
    "@st.cache_data # Para que la app sea rápida y no recargue datos todo el tiempo\n",
    "def preparar_datos():\n",
    "    # Aquí asumo que ya tienes tu dataframe 'df_model' limpio\n",
    "    # Si vas a ejecutarlo localmente, usa: df = pd.read_csv(\"tu_archivo.csv\")\n",
    "    return df_model\n",
    "\n",
    "df = preparar_datos()\n",
    "\n",
    "# 4. BARRA LATERAL (FILTROS)\n",
    "st.sidebar.header(\"🎯 Define tu Perfil\")\n",
    "\n",
    "with st.sidebar:\n",
    "    sabor_input = st.selectbox(\"¿Qué sabor buscas?\", options=sorted(df['sabor'].dropna().unique()))\n",
    "    color_input = st.selectbox(\"Color preferido:\", options=sorted(df['color'].dropna().unique()))\n",
    "    abv_input = st.slider(\"Graduación Alcohólica (ABV %)\", 2.0, 15.0, 5.0, 0.5)\n",
    "    \n",
    "    opciones_ferm = [\"Todas\"] + sorted(df['fermentacion'].dropna().unique().tolist())\n",
    "    tipo_ferm = st.radio(\"Tipo de Fermentación:\", options=opciones_ferm)\n",
    "\n",
    "# 5. LÓGICA DE FILTRADO\n",
    "margen = 1.5\n",
    "filtro = (\n",
    "    (df['sabor'].str.contains(sabor_input, case=False)) & \n",
    "    (df['color'].str.contains(color_input, case=False)) &\n",
    "    (df['abv_prom_%'].between(abv_input - margen, abv_input + margen))\n",
    ")\n",
    "\n",
    "if tipo_ferm != \"Todas\":\n",
    "    filtro &= (df['fermentacion'] == tipo_ferm)\n",
    "\n",
    "recomendaciones = df[filtro].copy()\n",
    "\n",
    "# 6. MOSTRAR RESULTADOS\n",
    "st.subheader(f\"📊 Resultados encontrados: {len(recomendaciones)}\")\n",
    "\n",
    "if not recomendaciones.empty:\n",
    "    # Calcular error de proximidad para ordenar\n",
    "    recomendaciones['Proximidad'] = abs(recomendaciones['abv_prom_%'] - abv_input)\n",
    "    resultados = recomendaciones.sort_values(by='Proximidad').head(5)\n",
    "\n",
    "    # Crear columnas para las \"tarjetas\" de cerveza\n",
    "    cols = st.columns(len(resultados))\n",
    "    \n",
    "    for i, (idx, row) in enumerate(resultados.iterrows()):\n",
    "        with cols[i]:\n",
    "            st.info(f\"**{row['estilo'].upper()}**\")\n",
    "            st.metric(\"ABV\", f\"{row['abv_prom_%']}%\")\n",
    "            st.write(f\"**Amargor:** {row['ibu_prom']} IBU\")\n",
    "            st.write(f\"**Categoría:** {row['fermentacion']}\")\n",
    "            st.caption(f\"Cluster: {row['nombre_cluster']}\")\n",
    "            \n",
    "    # Mostrar tabla detallada abajo\n",
    "    st.divider()\n",
    "    st.dataframe(resultados[['estilo', 'fermentacion', 'abv_prom_%', 'ibu_prom', 'origen', 'nombre_cluster']], use_container_width=True)\n",
    "else:\n",
    "    st.warning(\"⚠️ No se encontraron coincidencias exactas. Prueba ajustando el slider de ABV o cambiando el tipo de fermentación.\")\n",
    "\n",
    "# 7. PIE DE PÁGINA\n",
    "st.sidebar.info(\"Proyecto desarrollado para Portafolio de Análisis de Datos.\")"
   ]
  },
