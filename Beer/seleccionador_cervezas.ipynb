    "df_model = datos_cervezas.dropna(subset=features).copy()\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(df_model[features])\n",
    "\n",
    "n_clusters = 4\n",
    "kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)\n",
    "df_model['cluster'] = kmeans.fit_predict(X_scaled)\n",
    "\n",
    "nombres_clusters = {\n",
    "    0: \"Refrescantes y Ligeras\",\n",
    "    1: \"Intensas y Amargas (IPAs)\",\n",
    "    2: \"Robustas y Alcohólicas\",\n",
    "    3: \"Equilibradas y Maltosas\"\n",
    "}\n",
    "df_model['nombre_cluster'] = df_model['cluster'].map(nombres_clusters)\n",
    "\n",
    "# ==========================================\n",
    "# 2. VISUALIZACIÓN DE ALTO CONTRASTE\n",
    "# ==========================================\n",
    "plt.figure(figsize=(12, 7))\n",
    "# Naranja vibrante, Azul eléctrico, Verde esmeralda, Púrpura\n",
    "colores_contraste = ['#FF5733', '#3357FF', '#2ECC71', '#9B59B6']\n",
    "\n",
    "sns.scatterplot(\n",
    "    data=df_model, x='abv_prom_%', y='ibu_prom', hue='nombre_cluster', \n",
    "    palette=colores_contraste, s=160, alpha=0.9, edgecolor='white', linewidth=1\n",
    ")\n",
    "\n",
    "plt.title('Segmentación Técnica: Potencia vs Amargor', fontsize=16, fontweight='bold', pad=20)\n",
    "plt.xlabel('Graduación Alcohólica (ABV %)', fontsize=12)\n",
    "plt.ylabel('Nivel de Amargor (IBU)', fontsize=12)\n",
    "plt.legend(title='Grupo de Cluster', bbox_to_anchor=(1.05, 1), loc='upper left', shadow=True)\n",
    "plt.grid(True, linestyle=':', alpha=0.4)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ==========================================\n",
    "# 3. SELECCIONADOR INTEGRAL (FERMENTACIÓN CATEGÓRICA)\n",
    "# ==========================================\n",
    "def seleccionador_maestro(sabor_elegido, color_elegido, abv_deseado, tipo_fermentacion):\n",
    "    # Margen de flexibilidad para el alcohol\n",
    "    margen = 1.5\n",
    "    \n",
    "    # Filtro base: Sabor, Color y Rango de ABV\n",
    "    filtro = (\n",
    "        (df_model['sabor'].str.contains(sabor_elegido, case=False, na=False)) & \n",
    "        (df_model['color'].str.contains(color_elegido, case=False, na=False)) &\n",
    "        (df_model['abv_prom_%'].between(abv_deseado - margen, abv_deseado + margen))\n",
    "    )\n",
    "    \n",
    "    # Filtro opcional para Lager, Ale o Lámbica\n",
    "    if tipo_fermentacion != \"Todas\":\n",
    "        filtro &= (df_model['fermentacion'].str.contains(tipo_fermentacion, case=False, na=False))\n",
    "    \n",
    "    recomendaciones = df_model[filtro].copy()\n",
    "    total = len(recomendaciones)\n",
    "    \n",
    "    print(f\"\\n🔎 BUSCANDO: {sabor_elegido} | {color_elegido} | ~{abv_deseado}% ABV | Tipo: {tipo_fermentacion}\")\n",
    "    print(f\"📊 {total} estilos encontrados.\")\n",
    "    print(\"=\"*80)\n",
    "    \n",
    "    if total > 0:\n",
    "        # Ordenamos por cercanía al alcohol deseado\n",
    "        recomendaciones['error_abv'] = abs(recomendaciones['abv_prom_%'] - abv_deseado)\n",
    "        resultados = recomendaciones.sort_values(by='error_abv')\n",
    "        \n",
    "        for i, row in resultados.iterrows():\n",
    "            print(f\"🍺 ESTILO: {row['estilo'].upper()}\")\n",
    "            print(f\"   Familia: {row['fermentacion'].capitalize()} | Grupo: {row['nombre_cluster']}\")\n",
    "            print(f\"   Perfil: {row['abv_prom_%']}% ABV | {row['ibu_prom']} IBU | {row['intensidad']}\")\n",
    "            print(f\"   Origen: {row['origen']}\")\n",
    "            print(\"-\" * 80)\n",
    "    else:\n",
    "        print(\"❌ No hay coincidencias exactas. Intenta ampliar el rango de alcohol o elige 'Todas' en fermentación.\")\n",
    "\n",
    "# ==========================================\n",
    "# 4. INTERFAZ INTERACTIVA\n",
    "# ==========================================\n",
    "menu_sabor = widgets.Dropdown(options=sorted(df_model['sabor'].dropna().unique()), description='Sabor:')\n",
    "menu_color = widgets.Dropdown(options=sorted(df_model['color'].dropna().unique()), description='Color:')\n",
    "slider_abv = widgets.FloatSlider(value=5.0, min=2.0, max=15.0, step=0.5, description='ABV %:', continuous_update=False)\n",
    "\n",
    "# Definimos las categorías exactas del dataset + opción \"Todas\"\n",
    "opciones_ferm = [\"Todas\"] + sorted(df_model['fermentacion'].dropna().unique().tolist())\n",
    "menu_ferm = widgets.Dropdown(options=opciones_ferm, description='Tipo:')\n",
    "\n",
    "widgets.interact(\n",
    "    seleccionador_maestro, \n",
    "    sabor_elegido=menu_sabor, \n",
    "    color_elegido=menu_color, \n",
    "    abv_deseado=slider_abv,\n",
    "    tipo_fermentacion=menu_ferm\n",
    ")"
   ]
  },
