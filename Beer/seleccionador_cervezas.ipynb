    "fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n",
    "fig.suptitle(\"Exploración Visual - Estilos de Cerveza\", fontsize=16, fontweight=\"bold\")\n",
    "#fig.patch.set_facecolor(\"#FAFAF8\")\n",
    "#for ax in axes.flat:\n",
    "    #ax.set_facecolor(\"#FAFAF8\")\n",
    "    #ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
    "\n",
    "# ── Paleta de colores ──────────────────────────────────────────────────────\n",
    "colores_color  = {\"Pale\": \"#F2A623\", \"Dark\": \"#4A2C0A\", \"Amber\": \"#C45C1A\"}\n",
    "\n",
    "# 1. Obtenemos los orígenes únicos\n",
    "nombres_origen = datos_cervezas[\"origen\"].unique()\n",
    "\n",
    "# 2. Generamos una paleta con la misma cantidad de colores que orígenes\n",
    "paleta = sns.color_palette(\"deep\", len(nombres_origen)).as_hex()\n",
    "\n",
    "# 3. Creamos el diccionario automáticamente usando una comprensión de diccionario\n",
    "colores_origen = dict(zip(nombres_origen, paleta))\n",
    "# Gráfica 1: Cantidad de estilos por Origin \n",
    "ax1 = axes[0, 0]\n",
    "origen_counts = datos_cervezas[\"origen\"].value_counts()\n",
    "bars = ax1.barh(origen_counts.index, origen_counts.values,\n",
    "                color=[colores_origen.get(o, \"#888\") for o in origen_counts.index],\n",
    "                edgecolor=\"white\", height=0.9)\n",
    "ax1.set_title(\"Estilos por origen\", fontsize=12)\n",
    "ax1.set_xlabel(\"Cantidad de estilos\")\n",
    "for bar, val in zip(bars, origen_counts.values):\n",
    "    ax1.text(bar.get_width() + 0.1, bar.get_y() + bar.get_height()/2,\n",
    "             str(val), va=\"center\", fontsize=10)\n",
